; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Shadow Siege"
config/description="A tower defense game set in a magical continent"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.3")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/game_manager.gd"
DayNightCycle="*res://scripts/day_night_cycle.gd"
ExplorationSystem="*res://scripts/exploration_system.gd"
CastleSystem="*res://scripts/castle_system.gd"
ExpeditionSystem="*res://scripts/expedition_system.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"

